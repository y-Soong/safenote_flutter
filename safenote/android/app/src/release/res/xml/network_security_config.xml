<?xml version="1.0" encoding="utf-8"?>
<!--
  release 빌드용 네트워크 보안 설정.

  [DHCP 현장테스트 대응]
  release 빌드를 사내 LAN 백엔드(http://<PC IP>:8080)로 붙여 테스트하는데, DHCP 로 PC IP 가
  매번 바뀐다. Android 네트워크 보안 설정의 <domain> 은 IP 와일드카드/대역(172.30.1.*)을
  지원하지 않아 개별 IP 를 핀(pin)하면 IP 가 바뀔 때마다 ERR_CLEARTEXT_NOT_PERMITTED 로 막힌다.
  따라서 base-config 에서 cleartext 를 허용해 어떤 LAN IP 든 평문 http 로 붙을 수 있게 한다.
  (localhost 번들서버 / 카카오 http 타일 등도 base-config 로 함께 허용됨 → 개별 화이트리스트 불필요)

  ※ 운영(스토어) 배포용 하드닝 빌드에서는 반드시 되돌릴 것:
     - cleartextTrafficPermitted="false" 로 변경
     - 운영 백엔드는 HTTPS 도메인으로 전환(평문 미사용)
     - 필요한 외부 http 호스트만 domain-config 화이트리스트로 한정
     (가능하면 별도 build flavor 로 운영/현장테스트 설정을 분리 권장)
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system"/>
            <!-- mkcert 등 사용자 설치 인증서 신뢰(LAN HTTPS dev 서버 8082 대비) -->
            <certificates src="user"/>
        </trust-anchors>
    </base-config>
</network-security-config>
