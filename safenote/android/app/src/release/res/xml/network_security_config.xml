<?xml version="1.0" encoding="utf-8"?>
<!--
  release(스토어 배포) 빌드용 네트워크 보안 설정 — 하드닝 버전.

  원칙:
    - 평문(cleartext) HTTP 전면 차단, 시스템 인증서만 신뢰(사용자 설치 인증서 불신).
    - 운영 백엔드(APP_BASE_URL)는 반드시 HTTPS 도메인이어야 한다.

  평문 예외(화이트리스트) 2종:
    1) localhost/127.0.0.1 — 번들 Vue 자산을 서빙하는 InAppLocalhostServer(web_app.dart).
       기기 내부 루프백 통신이라 외부 노출이 없다.
    2) kakao.com / daumcdn.net — 웹뷰 페이지 오리진이 http://localhost 라서
       Kakao Maps SDK 가 지도 타일을 http 로 요청하는 경우가 있다(외근 사유 지도 등).

  ※ 사내 LAN(DHCP) 현장테스트용 완화 설정이 필요하면 이 파일을 열지 말고
     debug 빌드(src/main 설정: cleartext+사용자 인증서 허용)를 사용할 것.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>

    <!-- 번들 자산 서버(루프백) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>

    <!-- Kakao Maps http 타일 대응 -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">kakao.com</domain>
        <domain includeSubdomains="true">daumcdn.net</domain>
    </domain-config>
</network-security-config>
